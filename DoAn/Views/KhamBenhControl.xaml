<UserControl x:Class="DoAn.Views.KhamBenhControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F7FC" Margin="10">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <GroupBox Header="Hàng đợi Bệnh nhân (Chờ khám)" Grid.Column="0" Margin="0,0,15,0" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <TextBox x:Name="txtTimKiemBN" Width="230" Height="35" VerticalContentAlignment="Center" Margin="0,0,10,0" Tag="Nhập Tên Bệnh nhân..."/>
                    <Button x:Name="btnTimBN" Content="🔍 Tìm" Width="80" Height="35" Background="#17A2B8" Foreground="White" FontWeight="Bold" Click="BtnTimBN_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>

                <DataGrid x:Name="dgDanhSachBN" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
                          SelectionMode="Single" SelectionChanged="DgDanhSachBN_SelectionChanged" RowHeight="35">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã Phiếu" Binding="{Binding MaPhieu}" Width="80"/>
                        <DataGridTextColumn Header="Tên Bệnh Nhân" Binding="{Binding TenBenhNhan}" Width="*"/>
                        <DataGridTextColumn Header="Giới Tính" Binding="{Binding GioiTinh}" Width="70"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>

        <GroupBox Header="Chi tiết Khám bệnh, Chỉ định &amp; Kê đơn" Grid.Column="1" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Đang khám cho:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock x:Name="txtTenBNDangKham" Grid.Column="1" Text="--- Chưa chọn ---" Foreground="#D35400" FontWeight="Bold" FontSize="18" VerticalAlignment="Center"/>

                        <Button x:Name="btnXemBenhAn" Grid.Column="2" Content="📖 Xem Bệnh Án Cũ" Background="#8E44AD" Foreground="White" Padding="15,8" FontWeight="Bold" Click="BtnXemBenhAn_Click" IsEnabled="False">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Mã phiếu khám:" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtMaPhieu" Height="30" IsReadOnly="True" Background="#ECF0F1"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Triệu chứng:" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtTrieuChung" Height="30" TextWrapping="Wrap" AcceptsReturn="True"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Kết luận (Chẩn đoán bệnh):" FontWeight="SemiBold" Foreground="#555" Margin="0,10,0,5"/>
                    <TextBox x:Name="txtChanDoan" Height="40" TextWrapping="Wrap" AcceptsReturn="True" FontWeight="Bold" Foreground="#C0392B" FontSize="14" Padding="5"/>
                </StackPanel>

                <GroupBox Header="1. Chỉ định Dịch vụ (Siêu âm, X-Quang, Xét nghiệm...)" Grid.Row="1" Margin="0,0,0,10" Foreground="#2980B9" FontWeight="Bold">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,10">
                            <ComboBox x:Name="cboDichVu" Width="300" Height="30" DisplayMemberPath="TenDichVu" Margin="0,0,10,0" FontWeight="Normal"/>
                            <Button Content="➕ Thêm Dịch vụ" Width="120" Height="30" Background="#3498DB" Foreground="White" FontWeight="Bold" Click="BtnThemDichVu_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="5"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                        <DataGrid x:Name="dgDichVuChiDinh" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" Background="White" FontWeight="Normal" RowHeight="30">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Tên Dịch Vụ Cận Lâm Sàng" Binding="{Binding TenDichVu}" Width="*"/>
                                <DataGridTextColumn Header="Thành Tiền" Binding="{Binding ThanhTien, StringFormat={}{0:N0} VNĐ}" Width="150"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </GroupBox>

                <GroupBox Header="2. Kê Đơn Thuốc" Grid.Row="2" Margin="0,0,0,15" Foreground="#27AE60" FontWeight="Bold">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,10">
                            <ComboBox x:Name="cboThuoc" Width="220" Height="30" DisplayMemberPath="TenThuoc" Margin="0,0,10,0" FontWeight="Normal"/>
                            <TextBox x:Name="txtSoLuongThuoc" Width="40" Height="30" Text="1" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Margin="0,0,10,0" ToolTip="Số lượng" FontWeight="Normal"/>
                            <TextBox x:Name="txtCachDung" Width="150" Height="30" VerticalContentAlignment="Center" Margin="0,0,10,0" ToolTip="Cách dùng" Text="Ngày uống 2 lần" FontWeight="Normal"/>
                            <Button Content="➕ Thêm Thuốc" Width="110" Height="30" Background="#27AE60" Foreground="White" FontWeight="Bold" Click="BtnThemThuoc_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="5"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                        <DataGrid x:Name="dgDonThuoc" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" Background="White" FontWeight="Normal" RowHeight="30">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Tên Thuốc" Binding="{Binding TenThuoc}" Width="*"/>
                                <DataGridTextColumn Header="SL" Binding="{Binding SoLuong}" Width="60"/>
                                <DataGridTextColumn Header="Cách Dùng" Binding="{Binding CachDung}" Width="200"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </GroupBox>

                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="🔄 Làm mới" Width="110" Height="45" Margin="0,0,15,0" Background="#95A5A6" Foreground="White" FontWeight="Bold" Click="BtnLamMoi_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Content="💾 LƯU PHIẾU KHÁM &amp; CHUYỂN THU NGÂN" Width="300" Height="45" Background="#2C3E50" Foreground="White" FontWeight="Bold" FontSize="14" Click="BtnLuuPhieu_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>