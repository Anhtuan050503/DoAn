<UserControl x:Class="DoAn.Views.DuyetLichHenControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F7FC">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="QUẢN LÝ &amp; DUYỆT LỊCH HẸN" FontSize="22" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Color="#D0D4DC" Opacity="0.5"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <Button Content="✔️ XÁC NHẬN LỊCH" Width="140" Height="40" Background="#27AE60" Foreground="White" FontWeight="Bold" Margin="0,0,10,0" Click="BtnXacNhan_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Content="❌ HỦY LỊCH" Width="110" Height="40" Background="#E74C3C" Foreground="White" FontWeight="Bold" Margin="0,0,10,0" Click="BtnHuy_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Content="🔄 Làm mới" Width="100" Height="40" Background="#3498DB" Foreground="White" Click="BtnLamMoi_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <TextBlock Text="(Vui lòng chọn 1 lịch hẹn trong bảng bên dưới rồi bấm nút xử lý)" VerticalAlignment="Center" Margin="15,0,0,0" FontStyle="Italic" Foreground="#7F8C8D"/>
                </StackPanel>

                <DataGrid x:Name="dgDuyetLich" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
                          Background="White" BorderThickness="0" RowHeight="35" FontSize="14" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã Lịch" Binding="{Binding MaLichHen}" Width="70"/>
                        <DataGridTextColumn Header="Tên Bệnh Nhân" Binding="{Binding HoTen}" Width="180"/>
                        <DataGridTextColumn Header="SĐT" Binding="{Binding SoDienThoai}" Width="100"/>
                        <DataGridTextColumn Header="Ngày Hẹn" Binding="{Binding NgayHen, StringFormat=dd/MM/yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Giờ" Binding="{Binding GioHen}" Width="70"/>
                        <DataGridTextColumn Header="Lý Do Khám" Binding="{Binding LyDoKham}" Width="*"/>
                        <DataGridTextColumn Header="Trạng Thái" Binding="{Binding TrangThai}" Width="130"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>