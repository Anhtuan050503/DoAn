<UserControl x:Class="DoAn.Views.QuanLyHoaDonControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             Background="#F4F7FC">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="QUẢN LÝ TẤT CẢ HÓA ĐƠN" FontSize="22" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>

        <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="15" Margin="0,45,0,20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Color="#D0D4DC" Opacity="0.5"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <TextBlock Text="Từ ngày:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#555" Margin="0,0,10,0"/>
                <DatePicker x:Name="dpTuNgay" Width="130" Height="35" VerticalContentAlignment="Center"/>

                <TextBlock Text="Đến ngày:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#555" Margin="20,0,10,0"/>
                <DatePicker x:Name="dpDenNgay" Width="130" Height="35" VerticalContentAlignment="Center" SelectedDate="{x:Static sys:DateTime.Now}"/>

                <TextBlock Text="Tìm kiếm:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#555" Margin="20,0,10,0"/>
                <TextBox x:Name="txtTimKiem" Width="200" Height="35" VerticalContentAlignment="Center" Tag="Mã HĐ hoặc Tên BN..."/>

                <Button Content="🔍 Lọc Dữ Liệu" Width="120" Height="35" Background="#3498DB" Foreground="White" FontWeight="Bold" Margin="20,0,0,0" Click="BtnLoc_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="🔄 Làm mới" Width="90" Height="35" Background="#95A5A6" Foreground="White" Margin="10,0,0,0" Click="BtnLamMoi_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Color="#D0D4DC" Opacity="0.5"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Danh sách Hóa đơn trong hệ thống" FontSize="16" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>

                <DataGrid x:Name="dgHoaDon" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
                          Background="White" BorderThickness="0" RowHeight="40" FontSize="14" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã HĐ" Binding="{Binding MaHoaDon}" Width="100"/>
                        <DataGridTextColumn Header="Tên Bệnh Nhân" Binding="{Binding TenBenhNhan}" Width="200"/>
                        <DataGridTextColumn Header="Tiền Khám" Binding="{Binding TienKham, StringFormat={}{0:N0} đ}" Width="120"/>
                        <DataGridTextColumn Header="Tiền Thuốc" Binding="{Binding TienThuoc, StringFormat={}{0:N0} đ}" Width="120"/>
                        <DataGridTextColumn Header="Tổng Tiền" Binding="{Binding TongTien, StringFormat={}{0:N0} đ}" Width="140"/>
                        <DataGridTextColumn Header="Ngày Thanh Toán" Binding="{Binding NgayThanhToan, StringFormat=dd/MM/yyyy HH:mm}" Width="150"/>
                        <DataGridTextColumn Header="Trạng Thái" Binding="{Binding TrangThai}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>