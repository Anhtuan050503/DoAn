<UserControl x:Class="DoAn.Views.VienPhiControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F7FC" Margin="10">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <GroupBox Header="Danh sách Bệnh nhân chờ thanh toán" Grid.Column="0" Margin="0,0,15,0" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <TextBox x:Name="txtTimKiem" Width="220" Height="35" VerticalContentAlignment="Center" Margin="0,0,10,0" Tag="Nhập Tên BN hoặc Mã Phiếu..."/>
                    <Button Content="🔍 Tìm kiếm" Width="100" Height="35" Background="#17A2B8" Foreground="White" FontWeight="Bold" Click="BtnTim_Click"/>
                </StackPanel>

                <DataGrid x:Name="dgChoThanhToan" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
                          SelectionMode="Single" SelectionChanged="DgChoThanhToan_SelectionChanged" RowHeight="35">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã Phiếu" Binding="{Binding MaPhieu}" Width="80"/>
                        <DataGridTextColumn Header="Tên Bệnh Nhân" Binding="{Binding TenBenhNhan}" Width="*"/>
                        <DataGridTextColumn Header="Ngày Khám" Binding="{Binding NgayKham, StringFormat=dd/MM/yyyy}" Width="90"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>

        <GroupBox Header="Chi tiết Hóa Đơn &amp; Thanh Toán" Grid.Column="1" Padding="15">
            <Grid x:Name="GridHoaDonToPrint" Background="White">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="HÓA ĐƠN VIỆN PHÍ" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#2C3E50"/>
                    <TextBlock x:Name="txtMaHoaDon" Text="Mã HĐ: HD-............" HorizontalAlignment="Center" Foreground="#7F8C8D" Margin="0,5,0,0" FontSize="14"/>
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="25"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Khách hàng:" FontWeight="Bold" Grid.Row="0" Grid.Column="0"/>
                    <TextBlock x:Name="txtTenBN" Text="---" Grid.Row="0" Grid.Column="1" FontSize="15" Foreground="#2980B9" FontWeight="Bold"/>

                    <TextBlock Text="Chẩn đoán:" FontWeight="Bold" Grid.Row="1" Grid.Column="0"/>
                    <TextBlock x:Name="txtChanDoan" Text="---" Grid.Row="1" Grid.Column="1" TextWrapping="Wrap" Foreground="#C0392B" FontWeight="Bold"/>
                </Grid>

                <TextBlock Text="1. Dịch vụ Cận lâm sàng:" Grid.Row="2" FontWeight="Bold" Margin="0,0,0,5" Foreground="#27AE60"/>
                <DataGrid x:Name="dgChiTietDichVu" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,25,0,15" RowHeight="30" BorderThickness="1">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Tên Dịch Vụ" Binding="{Binding TenDichVu}" Width="*"/>
                        <DataGridTextColumn Header="Đơn Giá" Binding="{Binding GiaDichVu, StringFormat={}{0:N0}}" Width="100"/>
                        <DataGridTextColumn Header="Thành Tiền" Binding="{Binding ThanhTien, StringFormat={}{0:N0}}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock Text="2. Đơn thuốc:" Grid.Row="3" FontWeight="Bold" Margin="0,0,0,5" Foreground="#8E44AD"/>
                <DataGrid x:Name="dgChiTietThuoc" Grid.Row="3" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,25,0,15" RowHeight="30" BorderThickness="1">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Tên Thuốc" Binding="{Binding TenThuoc}" Width="*"/>
                        <DataGridTextColumn Header="SL" Binding="{Binding SoLuong}" Width="60"/>
                        <DataGridTextColumn Header="Đơn Giá" Binding="{Binding GiaThuoc, StringFormat={}{0:N0}}" Width="100"/>
                        <DataGridTextColumn Header="Thành Tiền" Binding="{Binding ThanhTien, StringFormat={}{0:N0}}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="4" Background="#ECF0F1" Padding="15" CornerRadius="8" Margin="0,0,0,20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="25"/>
                            <RowDefinition Height="25"/>
                            <RowDefinition Height="25"/>
                            <RowDefinition Height="35"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Tiền công khám:" Grid.Row="0" Grid.Column="0" FontSize="14"/>
                        <TextBlock x:Name="txtTienKham" Text="0 VNĐ" Grid.Row="0" Grid.Column="1" TextAlignment="Right" FontSize="14" FontWeight="SemiBold"/>

                        <TextBlock Text="Tổng tiền dịch vụ:" Grid.Row="1" Grid.Column="0" FontSize="14"/>
                        <TextBlock x:Name="txtTienDichVu" Text="0 VNĐ" Grid.Row="1" Grid.Column="1" TextAlignment="Right" FontSize="14" FontWeight="SemiBold"/>

                        <TextBlock Text="Tổng tiền thuốc:" Grid.Row="2" Grid.Column="0" FontSize="14"/>
                        <TextBlock x:Name="txtTienThuoc" Text="0 VNĐ" Grid.Row="2" Grid.Column="1" TextAlignment="Right" FontSize="14" FontWeight="SemiBold"/>

                        <TextBlock Text="TỔNG THANH TOÁN:" Grid.Row="3" Grid.Column="0" FontSize="16" FontWeight="Bold" VerticalAlignment="Bottom"/>
                        <TextBlock x:Name="txtTongTien" Text="0 VNĐ" Grid.Row="3" Grid.Column="1" TextAlignment="Right" FontSize="22" FontWeight="Bold" Foreground="#E74C3C" VerticalAlignment="Bottom"/>
                    </Grid>
                </Border>

                <StackPanel x:Name="panelNutBam" Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnInHoaDon" Content="🖨️ In Hóa Đơn" Width="140" Height="45" Margin="0,0,15,0" Background="#34495E" Foreground="White" FontWeight="Bold" Click="BtnInHoaDon_Click" IsEnabled="False">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="btnThanhToan" Content="✅ XÁC NHẬN THU TIỀN" Width="200" Height="45" Background="#27AE60" Foreground="White" FontWeight="Bold" FontSize="14" Click="BtnThanhToan_Click" IsEnabled="False">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>